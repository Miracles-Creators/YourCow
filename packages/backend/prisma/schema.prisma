// YourCow Backend Database Schema for Prisma 7.x
// This file defines the off-chain data models that complement the on-chain smart contracts
//
// Design Principles:
// 1. On-chain = integrity, Off-chain = storage and business logic
// 2. All on-chain references are stored as strings for flexibility
// 3. Rich metadata lives here, hashes live on-chain
// 4. Audit trail is append-only (no deletions, only status changes)
// 5. DB-first: write off-chain record before sending on-chain tx

generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
}

// ============================================
// USERS, KYC, ROLES
// ============================================

model User {
  id                Int               @id @default(autoincrement())
  role              UserRole
  walletAddress     String?           @unique
  email             String            @unique
  name              String?
  status            UserStatus        @default(ACTIVE)
  kycProfile        KycProfile?
  producer          ProducerProfile?  @relation("ProducerUser")
  payments          Payment[]
  producerApprovals ProducerProfile[] @relation("ProducerApprovedBy")
  animalApprovals   Animal[]          @relation("AnimalApprovedBy")
  // P2P Marketplace relations
  accounts          Account[]
  offers            Offer[] // Offers created by this user (as seller)
  trades            Trade[] // Trades where this user is buyer
  // Tongo confidential payments
  tongoAccount      TongoAccount?
  tongoDeposits     TongoDeposit[]
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  primaryPurchases  PrimaryPurchase[]
}

enum UserRole {
  INVESTOR
  PRODUCER
  ADMIN
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  DELETED
}

model KycProfile {
  id          Int       @id @default(autoincrement())
  userId      Int       @unique
  user        User      @relation(fields: [userId], references: [id])
  status      KycStatus @default(PENDING)
  level       KycLevel  @default(BASIC)
  provider    String
  providerRef String    @unique
  reviewedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

enum KycStatus {
  PENDING
  APPROVED
  REJECTED
}

enum KycLevel {
  BASIC
  ADVANCED
}

model ProducerProfile {
  userId         Int            @id
  user           User           @relation("ProducerUser", fields: [userId], references: [id])
  senasaId       String         @unique
  status         ProducerStatus @default(PENDING)
  location       String?
  phone          String?
  yearsOperating Int?
  approvedById   Int?
  approvedBy     User?          @relation("ProducerApprovedBy", fields: [approvedById], references: [id])
  approvedAt     DateTime?
  lots           Lot[]

  @@index([approvedById])
}

enum ProducerStatus {
  PENDING
  ACTIVE
  SUSPENDED
  REJECTED
}

// ============================================
// LOTS & ANIMALS
// ============================================

model Lot {
  id          Int       @id @default(autoincrement())
  name        String
  description String
  status      LotStatus @default(DRAFT)

  // Location & Operation
  farmName       String
  location       String // Province/State + Country
  productionType ProductionType

  // Herd data (legally relevant for SENASA/traceability)
  cattleCount     Int // Number of animals in the lot
  averageWeightKg Int // Average weight per animal in kg
  initialWeightKg Int? // Initial average weight per animal in kg
  durationWeeks   Int // Expected fattening duration
  startDate       DateTime?
  endDate         DateTime?

  // Financing terms (contractually binding)
  totalShares     Int // Total investor shares
  pricePerShare   Int // Smallest unit
  investorPercent Float // Investor profit share percentage
  fundingDeadline DateTime? // Deadline to reach funding goal
  operatingCosts  Int? // Estimated costs

  // On-chain data (filled AFTER deploy)
  onChainLotId  Int?              @unique // lot_id from contract
  tokenAddress  String? // ERC20 shares token address
  txHash        String? // Creation tx hash
  metadataHash  String? // Poseidon hash of metadata
  onChainStatus OnChainSyncStatus @default(PENDING)

  // Relations
  producerId          Int
  producer            ProducerProfile @relation(fields: [producerId], references: [userId])
  animals             Animal[]
  payments            Payment[]
  settlement          Settlement?
  documents           LotDocument[]
  // P2P Marketplace relations
  marketplaceBalances Balance[]
  marketplaceOffers   Offer[]
  ledgerEntries       LedgerEntry[]

  // Flexible metadata (UI prefs, notes, non-critical data)
  notes    String? // Producer notes
  metadata Json? // Additional non-queryable data

  // Weight stats (grams) mirrored off-chain for queries
  initialTotalWeightGrams Int?
  currentTotalWeightGrams Int?

  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  primaryPurchases PrimaryPurchase[]

  @@index([producerId])
  @@index([status])
  @@index([fundingDeadline])
}

enum ProductionType {
  FEEDLOT
  PASTURE
  MIXED
}

model LotDocument {
  id         Int             @id @default(autoincrement())
  lotId      Int
  lot        Lot             @relation(fields: [lotId], references: [id])
  type       LotDocumentType
  fileUrl    String // S3/IPFS URL
  fileHash   String? // Hash for integrity verification
  uploadedAt DateTime        @default(now())

  @@index([lotId])
}

enum LotDocumentType {
  OWNERSHIP // Proof of cattle ownership
  LOT_DOCS // General lot documentation
  INSURANCE // Insurance certificates
  VIDEO // Video verification
  OTHER
}

enum LotStatus {
  DRAFT // Created in db, not on-chain
  PENDING_DEPLOY // Deploying on-chain
  FUNDING // Active, accepting investments
  FUNDED // Reached the goal
  ACTIVE // In fattening
  SETTLING
  COMPLETED
}

model Animal {
  id  Int    @id @default(autoincrement())
  eid String @unique // Electronic ID (SENASA ear tag)

  // On-chain data (filled after registration)
  onChainId          Int?              @unique // animal_id on contract
  registrationTxHash String?
  onChainStatus      OnChainSyncStatus @default(PENDING)

  // Relations
  lotId Int?
  lot   Lot? @relation(fields: [lotId], references: [id])

  // Animal data
  custodian          String // Feedlot wallet address
  status             AnimalStatus         @default(ALIVE)
  approvalStatus     AnimalApprovalStatus @default(PENDING_APPROVAL)
  approvedById       Int?
  approvedBy         User?                @relation("AnimalApprovedBy", fields: [approvedById], references: [id])
  initialWeightGrams Int?
  currentWeightGrams Int?
  profile            Json // breed, birthDate, sex, etc
  profileHash        String? // Poseidon hash of profile

  // Traceability
  traceEvents  TraceabilityEvent[]
  traceAnchors TraceAnchor[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([lotId])
  @@index([approvedById])
}

enum AnimalStatus {
  ALIVE
  SOLD
  DECEASED
  REMOVED
}

enum AnimalApprovalStatus {
  PENDING_APPROVAL
  APPROVED
  REJECTED
}

model TraceabilityEvent {
  id Int @id @default(autoincrement())

  // Relations
  animalId Int
  animal   Animal @relation(fields: [animalId], references: [id])

  // Event data
  eventType  TraceEventType
  timestamp  DateTime
  data       Json // Event-specific data (weight, vaccine, location, etc)
  recordedBy String // User/worker ID who recorded

  // Anchoring data (filled after on-chain anchoring)
  merkleRoot String?
  anchoredAt DateTime?

  createdAt DateTime @default(now())

  @@index([animalId])
}

enum TraceEventType {
  WEIGHING
  VACCINATION
  MOVEMENT
  HEALTH_CHECK
  FEEDING
  TREATMENT
}

model TraceAnchor {
  id               Int               @id @default(autoincrement())
  animalId         Int
  animal           Animal            @relation(fields: [animalId], references: [id])
  root             String // felt252 as string
  eventCount       Int
  timestamp        DateTime
  correctionReason String?
  txHash           String?
  onChainStatus    OnChainSyncStatus @default(PENDING)
  createdAt        DateTime          @default(now())

  @@index([animalId])
}

// ============================================
// INVESTMENTS & PAYMENTS
// ============================================

model Payment {
  id              Int    @id @default(autoincrement())
  paymentIntentId String @unique // Stripe/MercadoPago ID

  // Relations
  userId Int
  user   User @relation(fields: [userId], references: [id])
  lotId  Int
  lot    Lot  @relation(fields: [lotId], references: [id])

  // Payment details
  amountFiat   Int // In cents
  currency     String // USD, ARS
  status       PaymentStatus @default(PENDING)
  sourceApp    AppContext    @default(WEB)

  // On-chain data (filled after minting)
  txHash        String? // Starknet tx hash of mint
  onChainStatus OnChainSyncStatus @default(PENDING)

  createdAt   DateTime  @default(now())
  confirmedAt DateTime?

  @@index([userId])
  @@index([lotId])
}

enum PaymentStatus {
  PENDING
  CONFIRMED
  FAILED
  REFUNDED
}

enum AppContext {
  WEB
  MOBILE
  ADMIN
  API
}

// ============================================
// SETTLEMENTS
// ============================================
// Settlement = Liquidacion final del lote
// DB first: se crea en DB, luego se ancla on-chain

model Settlement {
  id    Int @id @default(autoincrement())
  lotId Int @unique
  lot   Lot @relation(fields: [lotId], references: [id])

  // Settlement data
  totalProceeds   Int // Fiat in smallest unit
  currency        String  @default("USD")
  finalReportHash String // Poseidon hash of final report
  finalReportUrl  String? // Link to IPFS/S3
  settledBy       String? // Contract address that executed settlement

  // Weight stats (grams)
  finalTotalWeightGrams   Int
  finalAverageWeightGrams Int
  initialTotalWeightGrams Int

  // On-chain sync status
  onChainStatus OnChainSyncStatus @default(PENDING)
  onChainTxHash String?

  // Timestamps
  settledAt DateTime? // When settlement was executed on-chain
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

enum OnChainSyncStatus {
  PENDING // Created in DB, not yet on-chain
  SYNCING // Transaction sent, waiting confirmation
  SYNCED // Confirmed on-chain
  FAILED // Transaction failed
}

// ============================================
// P2P MARKETPLACE
// ============================================

enum AccountType {
  TRADING // Normal user trading account
  FEES_COLLECTED // Protocol account where fees go
  PROTOCOL_VAULT // Represents the on-chain vault (for reconciliation)
}

enum AssetType {
  LOT_SHARES // Shares of a lot
  FIAT_ARS // Argentine Pesos
  FIAT_USD // US Dollars
}

enum OfferStatus {
  OPEN // Just created, accepting buys
  PARTIALLY_FILLED // Some shares sold //TODO: for mvp we don't want this 
  FILLED // 100% sold
  CANCELLED // Cancelled by seller
}

enum LedgerEventType {
  FIAT_DEPOSIT // Admin credits fiat to user
  SHARES_MINT // Admin credits shares to user
  TRADE_SHARES // Shares transfer in a trade
  TRADE_FIAT // Fiat transfer in a trade
  FEE_CHARGE // Fee charge (1%)
  TONGO_DEPOSIT // STRK funded into Tongo balance
  TONGO_WITHDRAWAL // STRK withdrawn from Tongo
  TONGO_TRANSFER // Tongo confidential transfer (trade settlement)
}

enum TradeStatus {
  PENDING // Trade initiated, shares locked
  TONGO_SETTLED // Tongo transfer confirmed on-chain
  COMPLETED // Shares transferred, ledger written
  FAILED // Tongo transfer failed, shares unlocked
}

enum PrimaryPurchaseStatus {
  PENDING // Fiat locked, mint not attempted
  ONCHAIN_MINTED // Mint succeeded, awaiting off-chain settlement
  COMPLETED // Fiat settled, shares credited, ledger written
  FAILED // Mint failed, fiat unlocked
}

enum AuditBatchStatus {
  PENDING // Created in DB, not yet anchored
  ANCHORING // Transaction sent, waiting confirmation
  ANCHORED // Confirmed on-chain
  FAILED // Transaction failed
}

model Account {
  id            Int           @id @default(autoincrement())
  userId        Int?
  user          User?         @relation(fields: [userId], references: [id])
  type          AccountType
  balances      Balance[]
  debitEntries  LedgerEntry[] @relation("LedgerDebitAccount")
  creditEntries LedgerEntry[] @relation("LedgerCreditAccount")
  createdAt     DateTime      @default(now())

  @@unique([userId, type])
  @@index([userId])
}

model Balance {
  id        Int       @id @default(autoincrement())
  accountId Int
  account   Account   @relation(fields: [accountId], references: [id])
  assetType AssetType
  lotId     Int? // Only for LOT_SHARES
  lot       Lot?      @relation(fields: [lotId], references: [id])
  available Decimal   @default(0) @db.Decimal(20, 2) //TODO: See if we can have only int for mvp
  locked    Decimal   @default(0) @db.Decimal(20, 2)
  updatedAt DateTime  @updatedAt

  @@unique([accountId, assetType, lotId])
  @@index([accountId])
  @@index([lotId])
}

model PrimaryPurchase {
  id             Int                   @id @default(autoincrement())
  userId         Int
  user           User                  @relation(fields: [userId], references: [id])
  lotId          Int
  lot            Lot                   @relation(fields: [lotId], references: [id])
  sharesAmount   Int
  totalCost      Int // sharesAmount * pricePerShare
  currency       String // USD, ARS
  idempotencyKey String                @unique
  status         PrimaryPurchaseStatus @default(PENDING)
  txHash         String?
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt

  @@index([userId])
  @@index([lotId])
  @@index([status])
}

model Offer {
  id             Int           @id @default(autoincrement())
  sellerId       Int
  seller         User          @relation(fields: [sellerId], references: [id])
  lotId          Int
  lot            Lot           @relation(fields: [lotId], references: [id])
  sharesAmount   Int // Total shares to sell
  pricePerShare  Int // Price per share in smallest fiat unit
  strkPricePerShare String? // Price per share in STRK wei (for STRK offers)
  currency       String        @default("STRK")
  sharesFilled   Int           @default(0) // How many already sold - TODO: For mvp not permit partially sale
  status         OfferStatus   @default(OPEN)
  idempotencyKey String        @unique
  trades         Trade[]
  ledgerEntries  LedgerEntry[]
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([sellerId])
  @@index([lotId])
  @@index([status])
}

model Trade {
  id             Int           @id @default(autoincrement())
  offerId        Int
  offer          Offer         @relation(fields: [offerId], references: [id])
  buyerId        Int
  buyer          User          @relation(fields: [buyerId], references: [id])
  sharesAmount   Int
  totalPrice     Int // Fiat total in smallest unit
  strkTotalPrice String? // STRK wei total (for STRK trades)
  feeAmount      Int           @default(0) // 0% for hackathon
  currency       String        @default("STRK")
  status         TradeStatus   @default(PENDING)
  tongoTxHash    String? // Tongo transfer tx hash
  idempotencyKey String        @unique
  ledgerEntries  LedgerEntry[]
  settledAt      DateTime      @default(now())

  @@index([offerId])
  @@index([buyerId])
  @@index([status])
}

//TODO:Explain better this
model LedgerEntry {
  id              Int             @id @default(autoincrement())
  eventType       LedgerEventType
  debitAccountId  Int
  debitAccount    Account         @relation("LedgerDebitAccount", fields: [debitAccountId], references: [id])
  creditAccountId Int
  creditAccount   Account         @relation("LedgerCreditAccount", fields: [creditAccountId], references: [id])
  assetType       AssetType
  lotId           Int?
  lot             Lot?            @relation(fields: [lotId], references: [id])
  amount          Decimal         @db.Decimal(20, 2)
  tradeId         Int?
  trade           Trade?          @relation(fields: [tradeId], references: [id])
  offerId         Int?
  offer           Offer?          @relation(fields: [offerId], references: [id])
  txHash          String?
  description     String?
  metadata        Json?
  createdAt       DateTime        @default(now())

  @@index([debitAccountId])
  @@index([creditAccountId])
  @@index([tradeId])
  @@index([offerId])
  @@index([lotId])
}

// ============================================
// TONGO CONFIDENTIAL PAYMENTS
// ============================================

model TongoAccount {
  id                  String   @id @default(uuid())
  userId              Int      @unique
  user                User     @relation(fields: [userId], references: [id])
  tongoPublicKey      String // Tongo public key as hex (used as recipient in transfers)
  encryptedPrivateKey String // AES-256-GCM encrypted with per-user derived key
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model TongoDeposit {
  id        String   @id @default(uuid())
  userId    Int
  user      User     @relation(fields: [userId], references: [id])
  txHash    String   @unique // Idempotency: same STRK transfer can't credit twice
  amount    String // STRK wei as string
  status    String   @default("CONFIRMED")
  createdAt DateTime @default(now())

  @@index([userId])
}

model AuditBatch {
  id           Int              @id @default(autoincrement())
  fromLedgerId Int
  toLedgerId   Int
  batchHash    String // SHA256 hash of canonical JSON
  txHash       String? // Starknet tx hash
  blockNumber  Int?
  status       AuditBatchStatus @default(PENDING)
  createdAt    DateTime         @default(now())
}
