// YourCow Backend Database Schema for Prisma 7.x
// This file defines the off-chain data models that complement the on-chain smart contracts
//
// Design Principles:
// 1. On-chain = integrity, Off-chain = storage and business logic
// 2. All on-chain references are stored as strings for flexibility
// 3. Rich metadata lives here, hashes live on-chain
// 4. Audit trail is append-only (no deletions, only status changes)
// 5. DB-first: write off-chain record before sending on-chain tx

generator client {
  provider = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
}

// ============================================
// USERS, KYC, ROLES
// ============================================

model User {
  id            String     @id @default(uuid())
  role          UserRole
  walletAddress String?    @unique
  email         String     @unique
  name          String?
  status        UserStatus @default(ACTIVE)
  kycProfile    KycProfile?
  producer      ProducerProfile? @relation("ProducerUser")
  payments      Payment[]
  shareBalances ShareBalance[]
  shareTransfersFrom ShareTransfer[] @relation("ShareTransferFrom")
  shareTransfersTo   ShareTransfer[] @relation("ShareTransferTo")
  producerApprovals  ProducerProfile[] @relation("ProducerApprovedBy")
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
}

enum UserRole {
  INVESTOR
  PRODUCER
  ADMIN
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  DELETED
}

model KycProfile {
  id          String    @id @default(uuid())
  userId      String    @unique
  user        User      @relation(fields: [userId], references: [id])
  status      KycStatus @default(PENDING)
  level       KycLevel  @default(BASIC)
  provider    String
  providerRef String    @unique
  reviewedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

enum KycStatus {
  PENDING
  APPROVED
  REJECTED
}

enum KycLevel {
  BASIC
  ADVANCED
}

model ProducerProfile {
  id           String         @id @default(uuid())
  userId       String         @unique
  user         User           @relation("ProducerUser", fields: [userId], references: [id])
  senasaId     String         @unique
  status       ProducerStatus @default(PENDING)
  approvedById String?
  approvedBy   User?          @relation("ProducerApprovedBy", fields: [approvedById], references: [id])
  approvedAt   DateTime?
  lots         Lot[]

  @@index([approvedById])
}

enum ProducerStatus {
  PENDING
  ACTIVE
  SUSPENDED
  REJECTED
}

// ============================================
// LOTS & ANIMALS
// ============================================

model Lot {
  id            String    @id @default(uuid())
  name          String
  description   String
  totalShares   String    // u256 as string
  pricePerShare String    // u256 as string (smallest unit)
  startDate     DateTime?
  endDate       DateTime?
  status        LotStatus @default(DRAFT)

  // On-chain data (filled AFTER deploy)
  onChainLotId String? @unique // lot_id from contract
  tokenAddress String? // ERC20 shares token address
  txHash       String? // Creation tx hash
  metadataHash String? // Poseidon hash of metadata
  onChainStatus OnChainSyncStatus @default(PENDING)

  // Relations
  producerProfileId String
  producer          ProducerProfile @relation(fields: [producerProfileId], references: [id])
  animals           Animal[]
  payments          Payment[]
  settlement        Settlement?
  shareBalances     ShareBalance[]
  shareTransfers    ShareTransfer[]

  // Metadata
  metadata Json? // location, expectedAnimals, etc

  // Weight stats (grams) mirrored off-chain for queries
  initialTotalWeightGrams Int?
  currentTotalWeightGrams Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([producerProfileId])
}

enum LotStatus {
  DRAFT // Created in db, not on-chain
  PENDING_DEPLOY // Deploying on-chain
  FUNDING // Active, accepting investments
  FUNDED // Reached the goal
  ACTIVE // In fattening
  SETTLING
  COMPLETED
}

model Animal {
  id  String @id @default(uuid())
  eid String @unique // Electronic ID (SENASA ear tag)

  // On-chain data (filled after registration)
  onChainId String? @unique // animal_id on contract (u256 as string)
  registrationTxHash String?
  onChainStatus OnChainSyncStatus @default(PENDING)

  // Relations
  lotId String?
  lot   Lot?    @relation(fields: [lotId], references: [id])

  // Animal data
  custodian   String // Feedlot wallet address
  status      AnimalStatus @default(ALIVE)
  profile     Json // breed, birthDate, initialWeight, sex, etc
  profileHash String? // Poseidon hash of profile

  // Traceability
  traceEvents TraceabilityEvent[]
  traceAnchors TraceAnchor[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([lotId])
}

enum AnimalStatus {
  ALIVE
  SOLD
  DECEASED
  REMOVED
}

model TraceabilityEvent {
  id String @id @default(uuid())

  // Relations
  animalId String
  animal   Animal @relation(fields: [animalId], references: [id])

  // Event data
  eventType  TraceEventType
  timestamp  DateTime
  data       Json // Event-specific data (weight, vaccine, location, etc)
  recordedBy String // User/worker ID who recorded

  // Anchoring data (filled after on-chain anchoring)
  merkleRoot String?
  anchoredAt DateTime?

  createdAt DateTime @default(now())

  @@index([animalId])
}

enum TraceEventType {
  WEIGHING
  VACCINATION
  MOVEMENT
  HEALTH_CHECK
  FEEDING
  TREATMENT
}

model TraceAnchor {
  id         String   @id @default(uuid())
  animalId   String
  animal     Animal   @relation(fields: [animalId], references: [id])
  root       String   // felt252 as string
  eventCount Int
  timestamp  DateTime
  correctionReason String?
  txHash     String?
  onChainStatus OnChainSyncStatus @default(PENDING)
  createdAt  DateTime @default(now())

  @@index([animalId])
}

// ============================================
// INVESTMENTS & PAYMENTS
// ============================================

model Payment {
  id              String @id @default(uuid())
  paymentIntentId String @unique // Stripe/MercadoPago ID

  // Relations
  userId String
  user   User @relation(fields: [userId], references: [id])
  lotId  String
  lot    Lot  @relation(fields: [lotId], references: [id])

  // Payment details
  amountFiat   Int // In cents
  currency     String // USD, ARS
  sharesAmount String // u256 as string
  status       PaymentStatus @default(PENDING)
  sourceApp    AppContext     @default(WEB)

  // On-chain data (filled after minting)
  txHash String? // Starknet tx hash of mint
  onChainStatus OnChainSyncStatus @default(PENDING)

  createdAt   DateTime  @default(now())
  confirmedAt DateTime?

  @@index([userId])
  @@index([lotId])
}

enum PaymentStatus {
  PENDING
  CONFIRMED
  FAILED
  REFUNDED
}

enum AppContext {
  WEB
  MOBILE
  ADMIN
  API
}

model ShareBalance {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  lotId       String
  lot         Lot      @relation(fields: [lotId], references: [id])
  amount      BigInt
  lastSyncedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([userId, lotId])
  @@index([lotId])
}

model ShareTransfer {
  id        String   @id @default(uuid())
  lotId     String
  lot       Lot      @relation(fields: [lotId], references: [id])
  fromUserId String?
  fromUser   User?    @relation("ShareTransferFrom", fields: [fromUserId], references: [id])
  toUserId   String
  toUser     User     @relation("ShareTransferTo", fields: [toUserId], references: [id])
  amount    BigInt
  kind      ShareTransferKind
  txHash    String   @unique
  onChainStatus OnChainSyncStatus @default(PENDING)
  createdAt DateTime @default(now())

  @@index([lotId])
  @@index([fromUserId])
  @@index([toUserId])
}

enum ShareTransferKind {
  MINT
  TRANSFER
  BURN
}

// ============================================
// SETTLEMENTS
// ============================================
// Settlement = Liquidacion final del lote
// DB first: se crea en DB, luego se ancla on-chain

model Settlement {
  id    String @id @default(uuid())
  lotId String @unique
  lot   Lot    @relation(fields: [lotId], references: [id])

  // Settlement data
  totalProceeds           String  // u256 as string (fiat in smallest unit)
  currency                String  @default("USD")
  finalReportHash         String  // Poseidon hash of final report
  finalReportUrl          String? // Link to IPFS/S3
  settledBy               String? // Contract address that executed settlement

  // Weight stats (grams)
  finalTotalWeightGrams   Int
  finalAverageWeightGrams Int
  initialTotalWeightGrams Int

  // On-chain sync status
  onChainStatus OnChainSyncStatus @default(PENDING)
  onChainTxHash String?

  // Timestamps
  settledAt DateTime? // When settlement was executed on-chain
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

enum OnChainSyncStatus {
  PENDING  // Created in DB, not yet on-chain
  SYNCING  // Transaction sent, waiting confirmation
  SYNCED   // Confirmed on-chain
  FAILED   // Transaction failed
}
