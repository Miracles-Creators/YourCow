ENVIRONMENT="devnet"
STARKNET_RPC_DEVNET="http://127.0.0.1:5050/rpc"
STARKNET_RPC_SEPOLIA="https://api.cartridge.gg/x/starknet/sepolia"
PROTOCOL_OPERATOR_PRIVATE_KEY=
PROTOCOL_OPERATOR_ADDRESS=
SEPOLIA_OPERATOR_PRIVATE_KEY=
SEPOLIA_OPERATOR_ADDRESS=
PROTOCOL_VAULT_ADDRESS=
ATTESTOR_PRIVATE_KEY=
ATTESTOR_ADDRESS=
TONGO_MASTER_KEY=

ENABLE_KYC=false
