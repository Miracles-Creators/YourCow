PORT=3001
AUTH_SECRET=replace-with-strong-secret
CORS_ORIGIN=http://localhost:3000
DATABASE_URL="postgres://user@localhost:5432/tu-cow"

# Starknet — flip ENVIRONMENT to switch everything (devnet | sepolia)
ENVIRONMENT="devnet"
STARKNET_RPC_DEVNET="http://127.0.0.1:5050/rpc"
STARKNET_RPC_SEPOLIA="https://api.cartridge.gg/x/starknet/sepolia"
PROTOCOL_OPERATOR_PRIVATE_KEY=
PROTOCOL_OPERATOR_ADDRESS=
SEPOLIA_OPERATOR_PRIVATE_KEY=
SEPOLIA_OPERATOR_ADDRESS=
PROTOCOL_VAULT_ADDRESS=
ATTESTOR_PRIVATE_KEY=
ATTESTOR_ADDRESS=
TONGO_MASTER_KEY=

# CRE Oracle
ORACLE_API_KEY="123"

# NAV Relay (EVM -> Starknet)
ENABLE_NAV_RELAY=false
NAV_ORACLE_ADDRESS=0x2fE73aAa0132100C6f78e6Cb4ea101c279581286
SEPOLIA_EVM_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com

ENABLE_KYC=false
